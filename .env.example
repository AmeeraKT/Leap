# Copy to .env for local dev. In Vercel: Project → Settings → Environment Variables.
# All client-side keys must be prefixed with VITE_

# Optional — AI Resume Roaster (Career Vision)
VITE_MISTRAL_AI_RESUME_ROASTER=

# Optional — Content Studio (OpenRouter)
VITE_OPENROUTER_API_KEY=

# Optional — if switching from mock Supabase to real project
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=
